<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
<add name="Python FastCGI" path="*" verb="*" modules="FastCgiModule" scriptProcessor="D:\TT-Watch_tracker\env\Scripts\python.exe|D:\TT-Watch_tracker\env\Lib\site-packages\wfastcgi.py" resourceType="Unspecified" requireAccess="Script" />    </handlers>
    <security>
      <requestFiltering allowDoubleEscaping="true" />
    </security>
    <!--
      Perf fix: static assets (JS/CSS/images under /static/ and /media/) were
      previously matched by the "Python FastCGI" handler above (path="*"),
      so every request for them was queued through the FastCGI worker pool
      and round-tripped through Django/WSGI even though the Django VIEW time
      for those paths is 0ms - all the latency was FastCGI queue/dispatch
      overhead. The <location> overrides below reset the handler mapping for
      those two paths back to IIS's native StaticFileModule so they are
      served directly by IIS and never touch the Python worker pool.
    -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
    </staticContent>
  </system.webServer>
<appSettings>
    <add key="PYTHONPATH" value="D:\TT-Watch_tracker\watchcase_tracker" />
    <add key="WSGI_HANDLER" value="watchcase_tracker.wsgi.application" />
    <add key="DJANGO_SETTINGS_MODULE" value="watchcase_tracker.settings" />
</appSettings>
  <!--
    Root-cause fix (Plating Stk No hover images broken in Production):
    the <staticContent> block above documents an intent to hand /static/
    and /media/ back to IIS's native StaticFileModule, but the actual
    <location> handler overrides were never added. Without them the
    "Python FastCGI" handler (path="*") above keeps matching /media/*,
    forwarding it into Django/WSGI. Django's own urlpatterns only
    register the /media/ serving route when DEBUG=True or when running
    via "manage.py runserver" (see watchcase_tracker/urls.py,
    serve_local_media) - neither is true under IIS+wfastcgi with
    DEBUG=False - so every /media/... request 404s in Production while
    working locally under runserver. These <location> blocks restore
    the documented behavior: IIS serves /static/ and /media/ directly
    from disk, never touching the Python worker pool.
  -->
  <location path="static">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile_static" path="*" verb="*" modules="StaticFileModule" resourceType="File" requireAccess="Read" />
      </handlers>
    </system.webServer>
  </location>
  <location path="media">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile_media" path="*" verb="*" modules="StaticFileModule" resourceType="File" requireAccess="Read" />
      </handlers>
    </system.webServer>
  </location>
</configuration>