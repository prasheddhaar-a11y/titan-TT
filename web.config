<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS web.config — TTT Enterprise Manufacturing Workflow System
  =============================================================

  VAPT Security Hardening
  -----------------------
  This file addresses:
    #13  Programming Language/Version disclosure  — remove Server/X-Powered-By
    #26  Weak/Vulnerable SSL/TLS Cipher Suites    — TLS 1.2/1.3 only, strong ciphers
    #33  Sensitive info in responses              — strip debug/version headers
    #34  Weak ciphers/encoding                   — disable RC4, DES, 3DES, export ciphers

  NOTE on TLS/cipher configuration:
  ---------------------------------
  IIS itself does not control cipher suites through web.config — cipher-suite
  ordering is controlled at the Windows Schannel level via:
    - Windows Registry  (HKLM\SYSTEM\CurrentControlSet\Control\SecurityProviders\SCHANNEL)
    - Group Policy (Computer Configuration → Windows Settings → Security → …)
    - IIS Crypto tool (Nartac Software — free, GUI-based, recommended for ops)

  The <security><access> and <httpProtocol> sections here complement the OS-level
  cipher configuration documented in docs/IIS_TLS_Hardening.md.

  Apply the registry keys in scripts/IIS_TLS_Hardening.ps1 (see below) to enforce
  TLS 1.2/1.3 only with ECDHE-GCM and CHACHA20 cipher suites.
-->
<configuration>

  <system.webServer>

    <!-- ===================================================================
         VAPT #13 / #33 — Remove server/technology version headers
         =================================================================== -->
    <httpProtocol>
      <customHeaders>
        <!-- Remove IIS version from every response -->
        <remove name="X-Powered-By" />
        <remove name="Server" />
        <!-- Defense-in-depth: additional security headers
             (CSP and X-Frame-Options are also set by the Django application) -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy"
             value="accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" />
      </customHeaders>
    </httpProtocol>

    <!-- Remove Server header at the IIS level (requires URL Rewrite module) -->
    <rewrite>
      <outboundRules>
        <rule name="Remove Server Header" enabled="true">
          <match serverVariable="RESPONSE_Server" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
        <rule name="Remove X-Powered-By Header" enabled="true">
          <match serverVariable="RESPONSE_X-Powered-By" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
        <rule name="Remove X-AspNet-Version Header" enabled="true">
          <match serverVariable="RESPONSE_X-AspNet-Version" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
        <rule name="Remove X-AspNetMvc-Version Header" enabled="true">
          <match serverVariable="RESPONSE_X-AspNetMvc-Version" pattern=".+" />
          <action type="Rewrite" value="" />
        </rule>
      </outboundRules>
    </rewrite>

    <!-- ===================================================================
         Security hardening — error pages / default documents
         =================================================================== -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="400" />
      <remove statusCode="403" />
      <remove statusCode="404" />
      <remove statusCode="500" />
      <!-- Custom error pages must not disclose framework version or stack trace -->
      <error statusCode="400" responseMode="Redirect" path="/accounts/login/" />
      <error statusCode="403" responseMode="Redirect" path="/accounts/login/" />
      <error statusCode="404" responseMode="Redirect" path="/accounts/login/" />
      <error statusCode="500" responseMode="Redirect" path="/accounts/login/" />
    </httpErrors>

    <!-- Prevent directory listing -->
    <directoryBrowse enabled="false" />

    <!-- ===================================================================
         Force HTTPS — HTTP → HTTPS redirect (IIS rewrite rule)
         =================================================================== -->
    <!-- NOTE: enable the rule below once a valid TLS certificate is bound
         to the HTTPS binding on this IIS site. Comment out while testing. -->
    <!--
    <rewrite>
      <rules>
        <rule name="HTTP to HTTPS Redirect" enabled="true" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}"
                  redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>
    -->

  </system.webServer>

</configuration>
